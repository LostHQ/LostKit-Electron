{
  "name": "lostkit",
  "version": "1.0.4",
  "author": "LostHQ Team",
  "description": "LostKit",
  "license": "GNU General Public License v3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/LostHQ/LostKit-Electron.git"
  },
  "main": "src/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "build:win": "electron-builder --win --ia32 --x64",
    "build:linux": "electron-builder --linux --ia32 --x64",
    "dist": "electron-builder --dir",
    "clean": "rm -rf dist out"
  },
  "dependencies": {
    "electron-log": "^4.4.7",
    "electron-updater": "^6.7.3",
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "electron": "39.2.7",
    "electron-builder": "^26.4.0"
  },
  "build": {
    "appId": "rs.losthq.lostkit",
    "productName": "LostKit",
    "files": [
      "**/*"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://tools.losthq.rs/lostkit/"
      }
    ]
  }
}
